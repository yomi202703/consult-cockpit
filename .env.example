# Gemma (OpenAI-compatible) endpoint for the right lane. Internal-only.
# Copy to .env (gitignored) and fill in, then verify:
#
#   cp .env.example .env
#   ${EDITOR:-vim} .env
#   bash run.sh doctor
#
# env.py also falls back to ~/.claude/lib/improver/.env if no local .env exists,
# or set COCKPIT_ENV to point at any .env path.

export WORKER_LLM_BASE_URL="https://<your-openai-compat-host>/v1"
export WORKER_LLM_API_KEY="<your-api-key>"
export WORKER_LLM_MODEL="<model-id>"          # e.g. gemma-4-31B-it
export WORKER_LLM_PROVIDER="gemma"             # gemma | openai | ollama | vllm
