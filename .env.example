# Worker lane — any OpenAI-compatible endpoint (OpenAI, vLLM, ollama, Groq,
# OpenRouter, a local Gemma...). Copy to .env (gitignored), fill in, verify:
#
#   cp .env.example .env
#   ${EDITOR:-vim} .env
#   bash run.sh doctor
#
# The API key is better kept OUT of this file: store it in the macOS keychain
# with `bash run.sh auth set worker` and omit/leave WORKER_LLM_API_KEY empty.
# Precedence: explicit env var > keychain > this file.
# Or set COCKPIT_ENV to point at any .env path.

export WORKER_LLM_BASE_URL="https://<your-openai-compat-host>/v1"
export WORKER_LLM_MODEL="<model-id>"           # e.g. gemma-4-31B-it, gpt-5.2-mini
# export WORKER_LLM_API_KEY="<your-api-key>"   # prefer: bash run.sh auth set worker
# export WORKER_LLM_PROVIDER="openai"          # optional; openai|gemma|ollama|vllm
#                                              # (= keychain account name; default openai)

# Reader lane over an API — DORMANT, not wired yet: today the reader is the
# chatgpt-web scrape lane. These take effect when the API reader lands.
# export READER_LLM_BASE_URL="https://api.example.com/v1"
# export READER_LLM_MODEL="<model-id>"
# export READER_LLM_PROVIDER="openai"
# export READER_LLM_API_KEY=""                 # prefer: bash run.sh auth set reader

# worker の context window(トークン)。既定 16000(安全側)。
# 使用率がこれに達すると古いターンを自動で1つの要約に圧縮する。
# 例: gemma 256k なら
# WORKER_LLM_CONTEXT=256000
